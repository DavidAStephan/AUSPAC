# =============================================
# AUSPAC Project .gitignore
# =============================================

# --- Dynare auto-generated output ---
dynare/+*/
dynare/au_*/
dynare/aux/+*/
dynare/aux/aux_*/
dynare/aux/*.log
dynare/*.log
dynare/*.eps
dynare/*.json
dynare/**/checksum
dynare/**/model/bytecode/

# --- Script output logs and scratch ---
*.log
*.txt
dynare/*.txt
!dynare/paper_irf_peaks.txt
!dynare/au_pac_model_data_README.md

# --- MATLAB binaries ---
*.mat
*.asv

# --- Downloaded raw data (regenerated by download_*.m) ---
fred_*.csv
rba_*.csv
data/fred_*.csv

# --- Output images (regenerated by scripts) ---
*.png
dynare/*.png

# --- Paper artefacts are tracked exceptions ---
!dynare/paper_artifacts/*.png
!dynare/paper_artifacts/*.txt

# --- Tracked source PDFs (papers in references/) ---
# references/*.pdf are tracked

# --- Claude config ---
.claude/

# --- macOS ---
.DS_Store
**/.DS_Store
