# =============================================
# AUSPAC Project .gitignore
# =============================================

# --- Dynare auto-generated output ---
# `+<model>/` and `<model>/` are created by `dynare <model> json=compute`.
# Wildcards cover all current and future model variants.
dynare/+*/
dynare/au_*/
dynare/nk_*/
dynare/test_*/

# --- Dynare logs and bytecode (regenerated every run) ---
dynare/*.log
dynare/*.eps
dynare/**/checksum
dynare/**/model/bytecode/
dynare/**/metropolis/
dynare/**/graphs/

# --- Script output logs (one-off scratch output) ---
*.txt
dynare/*.txt

# --- MATLAB generated files ---
*.mat
*.asv

# --- Downloaded raw data (regenerated by download_data.m) ---
fred_*.csv
rba_*.csv
data/fred_*.csv
data/test_*.csv

# --- MATLAB logs ---
matlab_log*.txt
git_*.txt
push_*.txt

# --- Output images (regenerated by scripts) ---
*.png
dynare/*.png
# Paper artefacts are tracked exceptions to the global *.png / *.txt rules.
!dynare/paper_artifacts/*.png
!dynare/paper_artifacts/*.txt

# --- PDF and extraction artifacts ---
pdf_output.txt
# Note: references/*.pdf are tracked (source papers).
# Note: dynare/regen/*.py figure-regeneration helpers ARE tracked.

# --- Claude config ---
.claude/

# --- Temporary/generated files ---
dynare/smoother_data.*
dynare/pass1_results.mat
dynare/smoother_results.mat
dynare/pac_*_results.mat
tracked_files_list.txt
~ $ *

# --- HTML / R / IDE scratch ---
dynare/*.html
dynare/.Rhistory
**/.Rhistory

# --- Phase H regen artefacts (rebuilt from scripts) ---
dynare/mcmc_posterior_table.md
dynare/mcmc_writeback.txt
dynare/contrib_check.txt
dynare/temp_irfs_regime_*.mat

# --- macOS ---
.DS_Store
**/.DS_Store
