# =============================================
# AUSPAC Project .gitignore
# =============================================

# --- Dynare auto-generated output ---
# These are regenerated by `dynare <model> json=compute`
# +<model>/ contains compiled MATLAB functions (static, dynamic, etc.)
# <model>/ contains estimation output, MCMC chains, graphs, JSON
dynare/+*/
dynare/au_pac/
dynare/au_pac_var/
dynare/au_pac_mce/
dynare/au_pac_smooth/
dynare/au_esat/
dynare/au_esat_est/
dynare/au_pac_pre_migration/
dynare/nk_simple/
dynare/nk_discounted/
dynare/test_var_pac/
dynare/test_var_pac_multi/

# --- Dynare log files (regenerated every run) ---
dynare/*.log

# --- Script output logs (one-off scratch output) ---
*.txt
dynare/*.txt

# --- MATLAB generated files ---
*.mat
*.asv

# --- Downloaded raw data (regenerated by download_data.m) ---
fred_*.csv
rba_*.csv
data/fred_*.csv
data/test_*.csv

# --- MATLAB logs ---
matlab_log*.txt
git_*.txt
push_*.txt

# --- Output images (regenerated by scripts) ---
*.png
dynare/*.png
dynare/*.eps

# --- PDF and extraction artifacts ---
*.py
pdf_output.txt
# Note: wp736.pdf is tracked (reference paper)

# --- Claude config ---
.claude/

# --- Temporary/generated files ---
dynare/smoother_data.*
dynare/pass1_results.mat
dynare/smoother_results.mat
dynare/pac_*_results.mat
tracked_files_list.txt
